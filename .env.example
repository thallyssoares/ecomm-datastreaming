# ==========================================
# KAFKA E-COMMERCE DATASTREAM - ENVIRONMENT
# ==========================================
# Copie para .env e preencha os valores
# cp .env.example .env

# ==========================================
# GOOGLE CLOUD (OBRIGATÓRIO)
# ==========================================
GCP_PROJECT_ID=seu-projeto-gcp
GCP_REGION=us-central1
BQ_LOCATION=US

# BigQuery Datasets (serão criados pelo Terraform ou manualmente)
BQ_BRONZE_DATASET=bronze
BQ_SILVER_DATASET=silver
BQ_GOLD_DATASET=gold

# Service Account para CI/CD (JSON em uma linha)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# ==========================================
# KAFKA / REDPANDA (Local Docker)
# ==========================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=ecommerce-events
KAFKA_CONSUMER_GROUP=bytewax-consumer-group
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# ==========================================
# SIMULADOR
# ==========================================
EVENTS_PER_SECOND=10
USER_POOL_SIZE=1000
SESSION_DURATION_MINUTES=30
PRODUCT_CATALOG_SIZE=50
CATEGORY_COUNT=10

# Probabilidades do funil (devem somar ~1.0)
PROB_PAGE_VIEW=0.40
PROB_VIEW_ITEM=0.30
PROB_ADD_TO_CART=0.20
PROB_PURCHASE=0.10

# ==========================================
# BYTEWAX CONSUMER
# ==========================================
BATCH_SIZE=100
BATCH_TIMEOUT_SECONDS=5
WORKER_COUNT=1
WORKER_ID=0

# ==========================================
# DBT
# ==========================================
DBT_PROFILE_TARGET=dev
DBT_THREADS=4

# ==========================================
# DAGSTER
# ==========================================
DAGSTER_HOME=./dagster/dagster_home

# ==========================================
# SODA
# ==========================================
SODA_PROJECT_ID=${GCP_PROJECT_ID}
SODA_DATASET=${BQ_SILVER_DATASET}

# ==========================================
# LOOKER STUDIO (Opcional)
# ==========================================
# LOOKER_STUDIO_PROJECT_ID=${GCP_PROJECT_ID}
